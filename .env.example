# Credenciais: copie para `.env.local` (tem prioridade sobre `.env`) ou exporte no shell.

# xAI Grok (primário para perguntas normais)
XAI_API_KEY=xai-your-key-here
GROK_API_KEY=
AI_PROVIDER=grok
GROKAI_MODEL=grok-4.3-latest

# DeepSeek (fallback do Grok + reasoner para perguntas complexas)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner

# OpenAI (opcional, último fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
